// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum LabelType {
  INBOX
  SENT
  DRAFTS
  TRASH
  SPAM
  ARCHIVE
  CUSTOM
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core User Model ──────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  password         String?   @db.Text
  role             UserRole  @default(USER)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  /// JSON: UserPreferences object
  settings         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  mailAccounts     MailAccount[]
  labels           Label[]
  contacts         Contact[]
  filterRules      FilterRule[]
  drafts           Draft[]
  notificationLogs NotificationLog[]
  snoozedMessages  SnoozedMessage[]

  @@index([email])
  @@index([role])
}

// ─── Mail Account ─────────────────────────────────────────────────────────────

model MailAccount {
  id          String    @id @default(cuid())
  userId      String
  email       String
  displayName String?
  /// Encrypted JSON: { imapPassword, smtpPassword }
  credentials String    @db.Text
  imapHost    String
  imapPort    Int
  imapTls     Boolean   @default(true)
  smtpHost    String
  smtpPort    Int
  smtpSecure  Boolean   @default(false)
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  syncedAt    DateTime?
  color       String? // e.g. "#4f46e5"
  emoji       String? // e.g. "📧"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  drafts   Draft[]

  @@index([userId])
  @@index([userId, isDefault])
  @@index([email])
}

// ─── Thread ───────────────────────────────────────────────────────────────────

model Thread {
  id                String   @id @default(cuid())
  subject           String
  /// JSON: string[] — unique participant emails
  participantEmails Json     @default("[]")
  messageCount      Int      @default(0)
  unreadCount       Int      @default(0)
  lastMessageAt     DateTime
  /// JSON: string[] — label ids
  labelIds          Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messages Message[]

  @@index([lastMessageAt])
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id            String    @id @default(cuid())
  mailAccountId String
  messageId     String // RFC 2822 Message-ID header
  threadId      String?
  subject       String?
  fromEmail     String
  fromName      String?
  /// JSON: EmailAddress[]
  toAddresses   Json      @default("[]")
  /// JSON: EmailAddress[]
  ccAddresses   Json      @default("[]")
  /// JSON: EmailAddress[]
  bccAddresses  Json      @default("[]")
  bodyHtml      String?   @db.Text
  bodyText      String?   @db.Text
  /// Short preview snippet (first ~200 chars of plain text)
  snippet       String?
  isRead        Boolean   @default(false)
  isStarred     Boolean   @default(false)
  isSnoozed     Boolean   @default(false)
  snoozeUntil   DateTime?
  isArchived    Boolean   @default(false)
  isDeleted     Boolean   @default(false)
  isSent        Boolean   @default(false)
  isDraft       Boolean   @default(false)
  isSpam        Boolean   @default(false)
  sentAt        DateTime?
  receivedAt    DateTime?
  size          Int       @default(0)
  /// JSON: Record<string, string> — raw headers
  headers       Json      @default("{}")
  /// S3/R2 object key for full raw RFC 2822 message
  rawPath       String?
  uid           Int? // IMAP UID
  imapMailbox   String? // IMAP mailbox name (e.g. "INBOX")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  mailAccount    MailAccount     @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  thread         Thread?         @relation(fields: [threadId], references: [id])
  attachments    Attachment[]
  messageLabels  MessageLabel[]
  snoozedMessage SnoozedMessage?

  @@unique([mailAccountId, messageId])
  @@index([mailAccountId])
  @@index([threadId])
  @@index([isRead])
  @@index([isStarred])
  @@index([isDeleted])
  @@index([isDraft])
  @@index([isSent])
  @@index([receivedAt])
  @@index([mailAccountId, receivedAt])
  @@index([mailAccountId, isRead])
  @@index([mailAccountId, isDeleted])
}

// ─── Attachment ───────────────────────────────────────────────────────────────

model Attachment {
  id         String   @id @default(cuid())
  messageId  String
  filename   String
  mimeType   String
  size       Int
  /// S3/R2/local storage key
  storageKey String
  isInline   Boolean  @default(false)
  contentId  String? // CID for inline images
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ─── Label ────────────────────────────────────────────────────────────────────

model Label {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String? // e.g. "#ef4444"
  icon      String? // emoji or icon name
  isSystem  Boolean   @default(false)
  type      LabelType @default(CUSTOM)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageLabels MessageLabel[]

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, type])
  @@index([userId, order])
}

// ─── MessageLabel (join table) ───────────────────────────────────────────────

model MessageLabel {
  messageId String
  labelId   String
  addedAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([messageId, labelId])
  @@index([messageId])
  @@index([labelId])
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id              String    @id @default(cuid())
  userId          String
  email           String
  name            String?
  avatar          String?
  company         String?
  phone           String?
  notes           String?   @db.Text
  isBlocked       Boolean   @default(false)
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
  @@index([userId, email])
  @@index([userId, isBlocked])
}

// ─── FilterRule ───────────────────────────────────────────────────────────────

model FilterRule {
  id         String   @id @default(cuid())
  userId     String
  name       String
  /// JSON: FilterCondition[]
  conditions Json     @default("[]")
  /// JSON: FilterAction[]
  actions    Json     @default("[]")
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, order])
}

// ─── SnoozedMessage ──────────────────────────────────────────────────────────

model SnoozedMessage {
  id          String   @id @default(cuid())
  messageId   String   @unique
  userId      String
  snoozeUntil DateTime
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([snoozeUntil])
}

// ─── Draft ────────────────────────────────────────────────────────────────────

model Draft {
  id            String    @id @default(cuid())
  userId        String
  mailAccountId String?
  /// JSON: EmailAddress[]
  to            Json      @default("[]")
  /// JSON: EmailAddress[]
  cc            Json      @default("[]")
  /// JSON: EmailAddress[]
  bcc           Json      @default("[]")
  subject       String?
  bodyHtml      String?   @db.Text
  /// JSON: AttachmentInfo[] — references before upload completion
  attachments   Json      @default("[]")
  inReplyTo     String? // Message-ID being replied to
  references    String?   @db.Text // RFC references header
  scheduledAt   DateTime? // null = not scheduled
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailAccount MailAccount? @relation(fields: [mailAccountId], references: [id])

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([scheduledAt])
}

// ─── NotificationLog ─────────────────────────────────────────────────────────

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String // "new_message" | "digest" | "snooze_wakeup" | etc.
  isRead    Boolean  @default(false)
  /// JSON: arbitrary notification payload
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
}
