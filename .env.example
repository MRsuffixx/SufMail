# Since the ".env" file is gitignored, use this file as a template.
# Copy it to ".env" and fill in your values.
# When adding new variables, also update /src/env.js

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/mailforge"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── OAuth Providers ───────────────────────────────────────────────────────────
# Enable providers in src/config.ts → config.auth.providers
# Only fill in credentials for providers you enable.

# Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Microsoft
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ─── Magic Link (Email Provider) ───────────────────────────────────────────────
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@example.com"

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Upstash Redis URL or local: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# ─── Storage ───────────────────────────────────────────────────────────────────
# Provider: "s3" | "r2" | "local" — set in src/config.ts → config.storage.provider
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="mailforge-attachments"
STORAGE_REGION="us-east-1"
# For Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=""
NEXT_PUBLIC_STORAGE_PUBLIC_URL="/uploads"

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key: must be exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── Search (optional) ─────────────────────────────────────────────────────────
# Only needed if config.advanced.searchProvider = "meilisearch"
MEILISEARCH_HOST=""
MEILISEARCH_API_KEY=""
